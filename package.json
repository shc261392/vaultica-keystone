{
  "name": "@vaultica/keystone",
  "version": "1.0.0",
  "description": "Vaultica Design System - Single Source of Truth (SSoT) for brand tokens, AI context, and assets",
  "author": "Vaultica Team",
  "license": "UNLICENSED",
  "private": true,
  "volta": {
    "node": "24.13.1"
  },
  "packageManager": "pnpm@10.29.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaultica/keystone.git"
  },
  "main": "dist/tokens.js",
  "types": "dist/tokens.d.ts",
  "files": [
    "dist/",
    "tokens/",
    "ai/",
    "assets/"
  ],
  "scripts": {
    "build": "tsx scripts/build-tokens.ts",
    "validate": "tsx scripts/validate.ts",
    "prebuild": "tsx scripts/validate.ts",
    "watch": "nodemon --watch tokens --ext json --exec 'tsx scripts/build-tokens.ts'",
    "clean": "rm -rf dist/*",
    "rebuild": "rm -rf dist/* && tsx scripts/build-tokens.ts",
    "preview": "pnpm --dir preview dev",
    "preview:install": "pnpm --dir preview install",
    "preview:build": "pnpm --dir preview build",
    "lint": "biome check scripts/ && markdownlint-cli2 '**/*.md' '#node_modules' '#preview'",
    "lint:fix": "biome check --write scripts/",
    "format": "biome format --write src/ scripts/",
    "typecheck": "tsc --noEmit",
    "check:truth": "tsx scripts/check-truth.ts",
    "audit": "pnpm audit --audit-level=moderate",
    "prepare": "husky install || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@commitlint/types": "^20.4.0",
    "@types/node": "^25.2.3",
    "cspell": "^8.3.0",
    "husky": "^9.0.10",
    "lint-staged": "^15.2.2",
    "markdownlint-cli2": "^0.21.0",
    "nodemon": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "scripts/**/*.ts": [
      "biome check --write --unsafe"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ]
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "vaultica",
    "brand",
    "css-variables",
    "tailwind"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0 <11.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
